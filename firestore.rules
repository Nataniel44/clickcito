rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // FUNCIONES AUXILIARES (Helper Functions)
    // ==========================================
    
    // Verifica si el usuario actual está logueado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica si el documento de usuario tiene rol "admin_clickcito"
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin_clickcito';
    }

    // Verifica si el usuario tiene rol "dueño_negocio"
    function isDueno() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'dueño_negocio';
    }

    // Verifica si el usuario logueado está asociado al id_negocio del documento que intenta modificar
    // Nota: El documento de usuario dueño_negocio DEBE contener una propiedad "id_negocio"
    // para que esta regla funcione adecuadamente sin riesgo de que un aserradero modifique una pizzería.
    function isOwnerOfThisTenant(idNegocioUrl) {
       return isDueno() && 
              get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.id_negocio == idNegocioUrl;
    }
    
    // ==========================================
    // REGLAS POR COLECCIÓN
    // ==========================================

    // COLECCIÓN NEGOCIOS
    match /negocios/{idNegocio} {
      // Cualquier persona puede leer el negocio (clientes no logueados para ver el catálogo)
      allow read: if true; 
      // Solo Admin de Clickcito puede CREAR nuevos negocios
      allow create: if isAdmin();
      // El dueño del negocio o Super Admin puede actualizarlo
      allow update: if isAdmin() || isOwnerOfThisTenant(idNegocio);
      // Solo el Admin puede borrar un negocio
      allow delete: if isAdmin();
    }

    // COLECCIÓN PRODUCTOS DEL CATÁLOGO (Multi-Tenant)
    match /productos_catalogo/{productoId} {
      // Cualquiera puede leer el catálogo
      allow read: if true;
      
      // Para crear, actualizar o borrar un producto
      // Validamos que el request tenga un id_negocio (en update usamos resource.data y en create request.resource.data)
      allow create: if isAdmin() || 
                    (isOwnerOfThisTenant(request.resource.data.id_negocio));
                    
      allow update, delete: if isAdmin() || 
                    (isOwnerOfThisTenant(resource.data.id_negocio));
    }

    // COLECCIÓN USUARIOS
    match /usuarios/{userId} {
      // Un usuario sólo puede leer y escribir su propio documento (o admin general)
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // COLECCIÓN TRANSACCIONES
    match /transacciones/{transaccionId} {
      // ==========================================
      // LECTURA
      // ==========================================
      // Puede leer si:
      // 1. Es el cliente_final dueño de la transacción (match id_usuario)
      // 2. Es el dueño_negocio dueño del id_negocio al que pertenece la transacción
      // 3. Es admin de Clickcito
      allow read: if isAuthenticated() && (
        resource.data.id_usuario == request.auth.uid || 
        isOwnerOfThisTenant(resource.data.id_negocio) ||
        isAdmin()
      );

      // ==========================================
      // CREACIÓN
      // ==========================================
      // Cualquier usuario autenticado (cliente final) puede crear una transacción hacia un negocio.
      // Se obliga que el id_usuario enviado en la transacción sea igual al auth.uid real
      allow create: if isAuthenticated() && 
                    request.resource.data.id_usuario == request.auth.uid;

      // ==========================================
      // ACTUALIZACIÓN (Cambios de estado)
      // ==========================================
      // Solo el dueño del negocio o un Admin pueden cambiar el estado o modificar la transacción
      allow update: if isAuthenticated() && (
         isOwnerOfThisTenant(resource.data.id_negocio) || 
         isAdmin()
      );
      
      // Borrar transacciones generalmente no es recomendado, lo limitamos al admin
      allow delete: if isAdmin();
    }
  }
}
