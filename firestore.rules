rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // FUNCIONES AUXILIARES (Helper Functions)
    // ==========================================
    function isAuthenticated() {
      return request.auth != null;
    }

    // Obtenemos la data del usuario de forma segura
    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (getUserData().rol == 'admin_clickcito' || getUserData().rol == 'admin');
    }

    function isDueno() {
      return isAuthenticated() && 
             getUserData().rol == 'dueño_negocio';
    }

    function isOwnerOfThisTenant(idNegocioUrl) {
       let user = getUserData();
       return isAuthenticated() && 
              (user.rol == 'dueño_negocio' || user.rol == 'admin_clickcito' || user.rol == 'admin') && 
              user.id_negocio == idNegocioUrl;
    }

    // ==========================================
    // REGLAS POR COLECCIÓN
    // ==========================================

    // COLECCIÓN PEDIDOS
    match /pedidos/{pedidoId} {
      allow create: if true; 
      allow read, update, delete: if isAdmin() || isOwnerOfThisTenant(resource.data.restauranteId);
    }
    
    // COLECCIÓN NEGOCIOS
    match /negocios/{idNegocio} {
      allow read: if true; 
      allow create: if isAdmin();
      // Permitimos actualización si es Admin o si el id_negocio del usuario coincide con el documento
      allow update: if isAdmin() || isOwnerOfThisTenant(idNegocio);
      allow delete: if isAdmin();
    }

    // COLECCIÓN PRODUCTOS DEL CATÁLOGO
    match /productos_catalogo/{productoId} {
      allow read: if true;
      allow create: if isAdmin() || isOwnerOfThisTenant(request.resource.data.id_negocio);
      allow update, delete: if isAdmin() || isOwnerOfThisTenant(resource.data.id_negocio);
    }

    // COLECCIÓN USUARIOS
    match /usuarios/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Permitimos que el propio usuario o el admin escriban (necesario para el primer perfil)
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // COLECCIÓN TRANSACCIONES
    match /transacciones/{transaccionId} {
      allow read: if isAuthenticated() && (
        resource.data.id_usuario == request.auth.uid || 
        isOwnerOfThisTenant(resource.data.id_negocio) ||
        isAdmin()
      );
      allow create: if true;
      allow update: if isAdmin() || isOwnerOfThisTenant(resource.data.id_negocio);
      allow delete: if isAdmin();
    }

    // COLECCIÓN REPORTES DE PEDIDOS
    match /reportes_pedidos/{reporteId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() || 
        isOwnerOfThisTenant(resource.data.id_negocio)
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isOwnerOfThisTenant(resource.data.id_negocio);
    }

    // COLECCIÓN LOGS DE ACTIVIDAD
    match /actividad_logs/{logId} {
      allow read: if isAdmin() || isOwnerOfThisTenant(resource.data.id_negocio);
      allow create: if isAdmin() || isOwnerOfThisTenant(request.resource.data.id_negocio);
      allow update, delete: if false;
    }
  }
}
